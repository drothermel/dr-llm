# Copy this file to .env for local development.
# Never commit real credentials.

# Local or hosted Postgres DSN used by read-side pool commands when --dsn is omitted.
DR_LLM_DATABASE_URL=postgresql://postgres:postgres@localhost:5500/dr_llm

# Admin-capable Postgres-compatible URL used by:
#   uv run dr-llm project sync-postgres PROJECT
# For Neon, use the direct connection string for a role that can create, rename,
# and drop databases.
DR_LLM_POSTGRES_SYNC_ADMIN_URL=postgresql://user:password@host/neondb?sslmode=require

# Optional test DSN override used by integration tests.
DR_LLM_TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/dr_llm_test
